{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=HSIEH-DESKTOP;Database=HMS_TEST;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=True;"
    //"DefaultConnection": "Server=RYANHSIEH;Database=HMS_TEST;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=True;"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ], // 載入擴充的套件
    "MinimumLevel": { // Log 等級設定
      "Default": "Information", // 全域預設等級
      "Override": { // .NET 框架會有非常多Log訊息(各種請求跟View頁面渲染)，設為Warning等級以減少Log訊息量
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [ // 輸出目的地
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ]
  }
}
