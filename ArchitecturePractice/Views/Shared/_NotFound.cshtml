@{
    ViewData["Title"] = "找不到頁面";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-warning">
                <div class="card-body text-center py-5">
                    <h1 class="display-1 text-warning mb-4">🤔</h1>
                    <h2 class="text-warning mb-3">哎呀！找不到這個頁面</h2>

                    <p class="lead text-muted mb-4">
                        您輸入的網址可能不正確，或者該頁面已被移除。
                    </p>

                    <div class="alert alert-light border">
                        <p class="mb-0 text-muted">
                            建議您檢查網址拼字，或是直接返回首頁重新搜尋。
                        </p>
                    </div>

                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg me-2">
                            <i class="bi bi-house-door"></i> 返回首頁
                        </a>
                        <button onclick="history.back()" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-left"></i> 返回上一頁
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>